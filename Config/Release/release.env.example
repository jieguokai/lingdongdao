# Copy this file to a private location such as:
#   ~/.config/codex-lobster-island/release.env
# Then source it before running scripts/release-doctor.sh or scripts/release-app.sh

export APPLE_DEVELOPER_IDENTITY="Developer ID Application: Your Name (TEAMID)"
export APPLE_NOTARY_PROFILE="codex-lobster-notary"

# Sparkle updater keys
export SPARKLE_PUBLIC_ED_KEY="your-public-ed25519-key"
# export SPARKLE_PRIVATE_ED_KEY_FILE="/absolute/path/to/private-ed25519.key"

# Hosted update artifacts
export DOWNLOAD_BASE_URL="https://downloads.example.com/codex-lobster-island"
export APPCAST_URL="https://downloads.example.com/codex-lobster-island/appcast.xml"
export RELEASE_NOTES_URL="https://downloads.example.com/codex-lobster-island/release-notes/0.1.0.html"
